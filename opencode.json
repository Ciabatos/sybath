{
  "$schema": "https://opencode.ai/config.json",
  "model": "lmstudio2/qwen_qwen3.5-9b",
  "permission": {
    "git *": "allow",
    "npm *": "allow",
    "grep *": "allow"
  },
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["cmd.exe", "/c", "npx", "-y", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "React Icons MCP": {
      "type": "local",
      "command": ["cmd.exe", "/c", "npx", "-y", "react-icons-mcp", "--stdio"],
      "enabled": true
    },
    "game-db": {
      "type": "remote",
      "url": "http://localhost:3000/mcp",
      "enabled": true
    }
  },
  "provider": {
    "lmstudio2": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio Glados",
      "options": {
        "baseURL": "http://192.168.0.184:1234/v1"
      },
      "models": {
        "qwen_qwen3.5-9b": {
          "name": "qwen_qwen3.5-9b"
        }
      }
    },
    "lmstudio1": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio Ciabatos",
      "options": {
        "baseURL": "http://192.168.0.160:1234/v1"
      },
      "models": {
        "qwen_qwen3.5-4b": {
          "name": "qwen_qwen3.5-4b"
        }
      }
    }
  }
}
