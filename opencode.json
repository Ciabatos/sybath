{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "grep": "allow",
    "glob": "allow",
    "read": "allow",
    "bash": "allow",
    "list": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "question": "allow"
  },
  "mcp": {
    "rpg-db": {
      "type": "local",
      "command": ["cmd.exe", "/c", "node", "lib/mpc/rpg-db-mcp-server/dist/index.js"],
      "enabled": true,
      "timeout": 640000
    },
    "shadcn": {
      "type": "local",
      "command": ["cmd.exe", "/c", "npx", "-y", "shadcn@latest", "mcp"],
      "enabled": true,
      "timeout": 640000
    },
    "React-Icons-MCP": {
      "type": "local",
      "command": ["cmd.exe", "/c", "npx", "-y", "react-icons-mcp", "--stdio"],
      "enabled": true,
      "timeout": 640000
    }
  },
  "provider": {
    "lmstudio2": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio Glados",
      "options": {
        "baseURL": "http://192.168.0.184:1234/v1",
        "timeout": 1200000000,
        "chunkTimeout": 600000000
      },
      "models": {
        "qwen3.6-35b-a3b": {
          "name": "qwen3.6-35b-a3b"
        },
        "qwen3.6-27b": {
          "name": "qwen3.6-27b"
        }
      }
    },
    "lmstudio1": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio Ciabatos",
      "options": {
        "baseURL": "http://192.168.0.160:1234/v1"
      },
      "models": {
        "qwen_qwen3.5-4b": {
          "name": "qwen_qwen3.5-4b"
        }
      }
    }
  }
}
