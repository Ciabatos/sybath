.overlay {
  display: flex;
  position: relative;
  flex-direction: row;
  animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
  from {
    transform: translateX(100%);
  }
  to {
    transform: translateX(0);
  }
}

.panel {
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #1a0f08 0%, #2b1810 50%, #1a0f08 100%);
  height: 100%;
  overflow: hidden;
}